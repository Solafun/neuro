{
    "functions": {
        "api/**/*.js": {
            "maxDuration": 60
        }
    },
    "env": {
        "NODE_NO_WARNINGS": "1"
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}